{
  "buildCommand": "pnpm --filter @workspace/zarith run build",
  "outputDirectory": "artifacts/zarith/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "env": {
    "BASE_PATH": "/",
    "NODE_ENV": "production"
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
