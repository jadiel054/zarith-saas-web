{
  "version": 2,
  "buildCommand": "pnpm --config.verify-deps-before-run=false --filter @workspace/zarith run build",
  "outputDirectory": "artifacts/zarith/dist/public",
  "installCommand": "pnpm install --ignore-scripts",
  "framework": null,
  "env": {
    "BASE_PATH": "/",
    "NODE_ENV": "production",
    "VITE_COMMIT_SHA": "$VERCEL_GIT_COMMIT_SHA"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://zarith-api-server.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
