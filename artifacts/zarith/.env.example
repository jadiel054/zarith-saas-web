# API Keys - Configuração de variáveis de ambiente
# Estas variáveis são usadas como fallback quando as chaves não estão no localStorage
# Para usar em produção (Vercel), configure estas variáveis no painel de ambiente

# Groq API Key (Llama 3.3 70B)
VITE_GROQ_API_KEY=

# OpenRouter API Key (Qwen, DeepSeek, GLM)
VITE_OPENROUTER_API_KEY=

# Google Gemini API Key
VITE_GEMINI_API_KEY=

# GitHub Token (opcional, para features futuras)
VITE_GITHUB_TOKEN=

# Greptile API Key (opcional, para análise de código)
VITE_GREPTILE_API_KEY=

# Tavily API Key (opcional, para web search)
VITE_TAVILY_API_KEY=
